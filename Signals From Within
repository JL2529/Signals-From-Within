#include <Adafruit_CircuitPlayground.h>

#define sensorA_Pin A2

int sensorA_value = 0;

int pressureThreshold = 1000;
float soundThreshold = 67;

float soundLevel;

void setup() {
  CircuitPlayground.begin();
  Serial.begin(9600);
}

void loop() {

  sensorA_value = analogRead(sensorA_Pin);

  soundLevel = CircuitPlayground.mic.soundPressureLevel(10);

  Serial.print("Pressure: ");
  Serial.print(sensorA_value);
  Serial.print("   Sound: ");
  Serial.println(soundLevel);

  if (sensorA_value < pressureThreshold && soundLevel < soundThreshold) {

    for (int i = 0; i < 10; i++) {
      CircuitPlayground.setPixelColor(i, 0, 0, 255);
    }

  }

  else if (sensorA_value < pressureThreshold && soundLevel >= soundThreshold) {

    for (int i = 0; i < 10; i++) {
      CircuitPlayground.setPixelColor(i, 255, 100, 0);
      delay(120);
      CircuitPlayground.clearPixels();
    }

  }


  else if (sensorA_value >= pressureThreshold && soundLevel < soundThreshold) {

    for (int i = 0; i < 5; i++) {
      CircuitPlayground.setPixelColor(i, 255, 255, 0);
    }

    for (int i = 5; i < 10; i++) {
      CircuitPlayground.setPixelColor(i, 0, 0, 0);
    }

    delay(250);

    for (int i = 0; i < 5; i++) {
      CircuitPlayground.setPixelColor(i, 0, 0, 0);
    }

    for (int i = 5; i < 10; i++) {
      CircuitPlayground.setPixelColor(i, 255, 255, 0);
    }

    delay(250);
  }

  else if (sensorA_value >= pressureThreshold && soundLevel >= soundThreshold) {

    for (int i = 0; i < 10; i++) {
      CircuitPlayground.setPixelColor(i, 255, 0, 0);
    }

    delay(100);

    CircuitPlayground.clearPixels();

    delay(90);
  }

}

